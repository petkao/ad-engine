# PinkCurve Video Discovery - Streamlit Secrets Template
# Copy this file to secrets.toml for local development
# For Streamlit Community Cloud, add these in the app settings

# Required: Your OpenAI API key
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY = "sk-..."

# Required: PinkCurve MCP server URL
PINKCURVE_MCP_URL = "https://ad-engine-api-610270819686.us-west1.run.app/mcp"

# Optional: Email Agent A2A URL (for sending video ads via email)
EMAIL_AGENT_A2A_URL = "https://your-email-agent-url"
