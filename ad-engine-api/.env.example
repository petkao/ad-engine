# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=Colleen1

# Session
SESSION_SECRET=your-super-secret-session-key-change-this

# Optional: bearer token for machine-to-machine MCP access to protected API routes.
MCP_SERVICE_TOKEN=your-long-random-mcp-service-token

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Frontend URL
CLIENT_URL=http://localhost:3000

# Optional: billing support inbox. Falls back to the seller email if unset.
SUPPORT_EMAIL=support@example.com

# ─── LLM PROVIDERS ─────────────────────────────────────────────
# Creative Studio uses these for AI-powered content generation.
# Only ONE provider is required; set the one you want to use.

# Provider selection (default: openai)
# Options: openai, anthropic, gemini, nvidia, mock
LLM_PROVIDER=openai

# OpenAI (default provider)
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o  # Optional, defaults to gpt-4o

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Optional

# Google Gemini
# GOOGLE_AI_API_KEY=your-google-ai-api-key
# GEMINI_MODEL=gemini-1.5-pro  # Optional

# NVIDIA NIM (OpenAI-compatible endpoint)
# NVIDIA_API_KEY=nvapi-your-nvidia-api-key
# NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct  # Optional
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1  # Optional

# Provider configuration (applies to all providers)
# LLM_TIMEOUT=60000      # Request timeout in ms (default: 60000)
# LLM_MAX_RETRIES=2      # Retry count on failure (default: 2)
# LLM_TEMPERATURE=0.7    # Generation temperature 0-2 (default: 0.7)
