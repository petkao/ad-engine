{
  "hosting": {
    "public": "build",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": { "serviceId": "ad-engine-api", "region": "us-west1" }
      },
      {
        "source": "/auth/**",
        "run": { "serviceId": "ad-engine-api", "region": "us-west1" }
      },
      {
        "source": "/health",
        "run": { "serviceId": "ad-engine-api", "region": "us-west1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
